{
  "manifest_version": 3,
  "name": "CyberShield AI",
  "version": "1.0",
  "description": "AI-powered phishing & malware protection",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "activeTab",
    "downloads",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:5001/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "blocked.html",
        "blocked.css",
        "blocked.js",
        "icon.svg",
        "icon.png"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
